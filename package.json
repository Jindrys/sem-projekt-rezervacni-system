{
  "name": "rezervacni-system",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "node src/app.js",
    "dev": "nodemon src/app.js",
    "test": "jest --runInBand",
    "test:coverage": "c8 jest --runInBand",
    "test:unit": "jest tests/unit --runInBand",
    "test:integration": "jest tests/integration --runInBand"
  },
  "jest": {
    "testEnvironment": "node",
    "testTimeout": 15000,
    "setupFiles": [
      "dotenv/config"
    ],
    "projects": [
      {
        "displayName": "unit",
        "testMatch": [
          "**/tests/unit/**/*.test.js"
        ]
      },
      {
        "displayName": "integration",
        "testMatch": [
          "**/tests/integration/**/*.test.js"
        ],
        "globalSetup": "<rootDir>/tests/integration/globalSetup.js"
      }
    ]
  },
  "c8": {
    "reporter": [
      "text",
      "lcov",
      "html"
    ],
    "exclude": [
      "tests/**",
      "node_modules/**"
    ],
    "branches": 50,
    "lines": 70,
    "functions": 70,
    "statements": 70
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "pg": "^8.20.0",
    "pg-hstore": "^2.3.4",
    "sequelize": "^6.37.8"
  },
  "devDependencies": {
    "c8": "^11.0.0",
    "jest": "^30.3.0",
    "nodemon": "^3.1.14",
    "sequelize-mock": "^0.10.2",
    "supertest": "^7.2.2"
  }
}
